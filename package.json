{
  "name": "trip-split",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint --max-warnings 0 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "env:pull": "scripts/generate-local-env.sh",
    "env:validate": "node scripts/validate-config.mjs",
    "secrets-check": "node scripts/secrets-check.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@sentry/nextjs": "10.49.0",
    "@tanstack/react-query": "^5.100.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.12.1",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17",
    "happy-dom": "^20.9.0",
    "husky": "^9",
    "lint-staged": "^16",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.8",
    "shadcn": "^4.6.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4",
    "typescript": "^6",
    "typescript-eslint": "^8",
    "vercel": "^52.0.0",
    "vite": "^8.0.10",
    "vitest": "^4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --max-warnings 0 --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
